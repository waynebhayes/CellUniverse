sequenceDiagram
    actor User
    participant Main as main.cpp
    participant Args as initArgs()
    participant Config as YAML + BaseConfig
    participant Input as getImageFilePaths()
    participant Factory as CellFactory
    participant Lineage as Lineage
    participant FS as File System

    User->>Main: Run celluniverse <first> <last> <input> <output> <config.yaml> <initial.csv>

    alt argc < 7
        Main-->>User: Print usage and exit (code 1)
    else Valid arguments
        Main->>Args: Parse argv into Args
        Args-->>Main: firstFrame, lastFrame, input, output, config, initial

        Main->>Config: loadConfig(args.config)
        Config-->>Main: BaseConfig loaded + printed

        Main->>Input: getImageFilePaths(args.input, firstFrame, lastFrame, config)
        Input->>FS: Resolve pattern/dir/file and verify existence
        FS-->>Input: Image paths (.tif/.tiff)
        Input-->>Main: imageFilePaths (+ possible z_slices update)

        Main->>Main: set CELLUNIVERSE_INITIAL_FRAME_FILE (from first image)

        Main->>Factory: createCells(args.initial, z_offset, z_scaling)
        Factory->>FS: Read initial CSV
        FS-->>Factory: Initial cell rows
        Factory-->>Main: map<Path, vector<Spheroid>>

        Main->>Lineage: Construct Lineage(cells, imagePaths, config, output, firstFrame, continueFrom)
        Lineage-->>Main: Ready

        loop for each frame [0 .. lineage.length()-1]
            Main->>Lineage: optimize(frame)
            Main->>Lineage: copyCellsForward(frame + 1)
            Main->>Lineage: saveImages(frame)
            Lineage->>FS: Write rendered output images
            Main->>Lineage: saveCells(frame)
            Lineage->>FS: Write per-frame cell CSV
        end

        Main-->>User: Print elapsed time and completion message
    end
